; ============================================================
;  cam_id_test.ttl  -  Use Case View tha captured signal on one of the sensor
;  Shell Interface Reference Rev 1.0, Kaimasys 2025
;
;  Sync strategy: 'pause' after each command (no prompt matching).
;  The shell prompt has no trailing newline so waitln cannot match it.
;  waitln is only used for the 'cam id' output line which does end
;  with a newline.
;
;  Usage: TeraTerm > Control > Macro  (must already be connected)
; ============================================================

; ---- Already connected - no connect needed ----
; connect '/C=3 /BAUD=115200'

timeout = 3

sendln ''
waitln 'Kaitek> '
; Step 1 - lcd init
sendln 'lcd init'
waitln 'LCD initialized (vertical)'

if result = 1 then
    waitln 'Kaitek> '
; Step 2 - lcd bl 100
    sendln 'lcd bl 100'
    waitln 'Kaitek> '
; Step 3 - nrf init
    sendln 'nrf init 15000000'
    waitln 'NRF SPI ready: SCK=18 MOSI=19 MISO=20 CS=22 actual=15000000 Hz'
    if result = 1 then
        waitln 'Kaitek> '
; Step 4 - prime slave
        sendln 'nrf xfer AB AB AB AB'
        waitln 'Kaitek> '
; Step 5 - nrf stream start
        sendln 'nrf stream start'
        waitln 'Kaitek> '
    else
        messagebox 'FAIL: NRF SPI initialization failed. Check connections and power.' 'NRF Test'
        waitln 'Kaitek> '
    endif
else
    messagebox 'FAIL: LCD initialization failed. Check connections and power.' 'LCD Test'
    waitln 'Kaitek> '
endif
end

