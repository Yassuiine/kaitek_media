; ============================================================
;  live_cam_test.ttl  -  Use Case 6.3: Live Camera Prieview on LCD
;  Shell Interface Reference Rev 1.0, Kaimasys 2025
;
;  Sync strategy: wait for 'Kaitek> ' after each command .
;
;  Usage: TeraTerm > Control > Macro  (must already be connected)
; ============================================================

; ---- Already connected - no connect needed ----
; connect '/C=3 /BAUD=115200'

timeout = 3

sendln ''
waitln 'Kaitek> '
; Step 1 - lcd init
sendln 'lcd init'
waitln 'LCD initialized (vertical)'

if result = 1 then
    waitln 'Kaitek> '
; Step 2 - lcd bl 100
    sendln 'lcd bl 100'
    waitln 'Kaitek> '

; Step 3 - cam xclk
    sendln 'cam xclk'
    waitln 'Kaitek> '  

; Step 4 - cam defaults
;   Expected output line:  ID: 22080 then confirmation that the sensor init is applied.
;   If the ID does not match or camera is absent the timeout fires
;   and result = 0, giving the FAIL branch.
    sendln 'cam defaults'
    waitln 'ID: 22080'
    if result = 1 then
        waitln 'Kaitek> '
; Step 4 - lcd stream
        sendln 'lcd stream'
        waitln 'Kaitek> '
; Step 5 - lcd fps
        timeout = 5
        sendln 'lcd fps'
        waitln 'Kaitek> '
        messagebox 'PASS: Live camera preview displayed on LCD. Check for image and fps > 10.' 'Live Camera Test'
    else
        messagebox 'FAIL: ID 22080 not received. Check XCLK=GP11 SDA=GP22 SCL=GP23 and 3.3V supply.' 'Camera ID Test'    
    endif  
else
    messagebox 'FAIL: LCD initialization failed. Check connections and power.' 'LCD Test'
    waitln 'Kaitek> '
endif
end
