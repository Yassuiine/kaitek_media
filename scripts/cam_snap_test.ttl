; ============================================================
;  cam_snap_test.ttl  -  Use Case 6.2: Capture a Still Photo to SD
;  Shell Interface Reference Rev 1.0, Kaimasys 2025
;
;  Sync strategy: wait for 'Kaitek> ' after each command .
;
;  Usage: TeraTerm > Control > Macro  (must already be connected)
; ============================================================

; ---- Already connected - no connect needed ----
; connect '/C=3 /BAUD=115200'

timeout = 3

sendln ''
waitln 'Kaitek> '
; Step 1 - mount the SD card
sendln 'mount 0:'
waitln 'Kaitek> '

sendln 'chdrive 0:'
waitln 'Kaitek> '

; Step 2 - cam xclk
sendln 'cam xclk'
waitln 'Kaitek> '

; Step 3 - cam defaults
;   Expected output line:  ID: 22080 then confirmation that the sensor init is applied.
;   If the ID does not match or camera is absent the timeout fires
;   and result = 0, giving the FAIL branch.
sendln 'cam defaults'
waitln 'ID: 22080'
if result = 1 then
    waitln 'Kaitek> '
; Step 4 - cam snap
    sendln 'cam snap 0:/photo_cam_snap.bin'
    waitln 'Wrote 153600 bytes to 0:/photo_cam_snap.bin'
    waitln 'Kaitek> '
    messagebox 'PASS: Photo snap taken and saved to SD card.' 'Camera Snap Test'
else
    messagebox 'FAIL: ID 22080 not received. Check XCLK=GP11 SDA=GP22 SCL=GP23 and 3.3V supply.' 'Camera ID Test'    
endif

end
