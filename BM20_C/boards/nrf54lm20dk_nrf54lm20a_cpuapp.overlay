// &gpio1 {
// 	status = "okay";
// };

// &spi21 {
// 	compatible = "nordic,nrf-spis";
// 	status = "okay";
// 	def-char = <0xFF>;
// 	pinctrl-0 = <&spi21_slave_default>;
// 	pinctrl-1 = <&spi21_slave_sleep>;
// 	pinctrl-names = "default", "sleep";
// 	/delete-property/ rx-delay-supported;
// 	/delete-property/ rx-delay;
// };

/* ══════════════════════════════════════════════════════════════════════════════ */


/* ══════════════  PORT 2 — spi00 / HSSPI  (COMMENTED OUT)  ════════════════════
 *
 * To activate Port 2:
 *   1. Remove this opening comment marker (the line above).
 *   2. Remove the closing comment marker at the bottom of this section.
 *   3. Wrap the entire PORT 1 block above in a comment.
*/
/ {
	aliases {
		led = &led0;
		spis = &spi00;
	};
};

&pinctrl {
	spi00_slave_default: spi00_slave_default {
		group1 {
			psels = <NRF_PSEL(SPIS_SCK,  2, 6)>,
				<NRF_PSEL(SPIS_MOSI, 2, 9)>,
				<NRF_PSEL(SPIS_MISO, 2, 2)>,
				<NRF_PSEL(SPIS_CSN,  2, 10)>;
		};
	};

	spi00_slave_sleep: spi00_slave_sleep {
		group1 {
			psels = <NRF_PSEL(SPIS_SCK,  2, 6)>,
				<NRF_PSEL(SPIS_MOSI, 2, 9)>,
				<NRF_PSEL(SPIS_MISO, 2, 2)>,
				<NRF_PSEL(SPIS_CSN,  2, 10)>;
			low-power-enable;
		};
	};
};

&gpio2 {
	status = "okay";
};

&spi00 {
	compatible = "nordic,nrf-spis";
	status = "okay";
	def-char = <0xFF>;
	pinctrl-0 = <&spi00_slave_default>;
	pinctrl-1 = <&spi00_slave_sleep>;
	pinctrl-names = "default", "sleep";
	/delete-property/ rx-delay-supported;
	/delete-property/ rx-delay;
};

//══════════════════════════  END PORT 2  ═══════════════════════════════════════ 
