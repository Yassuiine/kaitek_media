/*
 * nRF54LM20 DK CPUAPP SPI-slave overlay.
 * Uses spi00 (SPIS00 / HSSPI) — the only peripheral that can reach P2 pins.
 * spi21 (P1 port, ≤8 MHz) cannot be mapped to P2; attempting to do so causes
 * the Zephyr SPIS driver to fail initialisation (device_is_ready() → false,
 * spi_transceive() returns -116 / ENOTSUP) and the firmware never arms.
 *
 * Dedicated HSSPI pins (nRF54LM20 PS §6.25):
 *   P2.06 SCK  →  Pico GPIO18
 *   P2.09 MOSI →  Pico GPIO19   (SDI on nRF side)
 *   P2.02 MISO →  Pico GPIO20   (board variant uses P2.02; P2.08 not routed)
 *   P2.10 CSN  →  Pico GPIO22
 */

/ {
	aliases {
		led = &led0;
		spis = &spi00;
	};
};

&pinctrl {
	spi00_slave_default: spi00_slave_default {
		group1 {
			psels = <NRF_PSEL(SPIS_SCK,  2, 6)>,
				<NRF_PSEL(SPIS_MOSI, 2, 9)>,
				<NRF_PSEL(SPIS_MISO, 2, 2)>,
				<NRF_PSEL(SPIS_CSN,  2, 10)>;
		};
	};

	spi00_slave_sleep: spi00_slave_sleep {
		group1 {
			psels = <NRF_PSEL(SPIS_SCK,  2, 6)>,
				<NRF_PSEL(SPIS_MOSI, 2, 9)>,
				<NRF_PSEL(SPIS_MISO, 2, 2)>,
				<NRF_PSEL(SPIS_CSN,  2, 10)>;
			low-power-enable;
		};
	};
};

&gpio2 {
	status = "okay";
};

&spi00 {
	compatible = "nordic,nrf-spis";
	status = "okay";
	def-char = <0xFF>;
	pinctrl-0 = <&spi00_slave_default>;
	pinctrl-1 = <&spi00_slave_sleep>;
	pinctrl-names = "default", "sleep";
	/delete-property/ rx-delay-supported;
	/delete-property/ rx-delay;
};
