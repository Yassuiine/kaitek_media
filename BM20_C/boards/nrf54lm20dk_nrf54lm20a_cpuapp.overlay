// /*
//  * nRF54LM20 DK CPUAPP SPI-slave overlay.
//  *
//  * Two complete configurations are provided below.  Only ONE may be active
//  * at a time.
//  *
//  * HOW TO SWITCH PORTS
//  * ────────────────────
//  *   Activate Port 1 (current):  the PORT 1 block is uncommented.
//  *                                Make sure the PORT 2 block stays inside
//  *                                its comment markers.
//  *
//  *   Activate Port 2:            wrap the entire PORT 1 block in  /* ... */
//  *                                then remove the opening and closing
//  *                                comment markers from the PORT 2 block.
//  *
//  * Pin mapping (Pico-side GPIO numbers are the same for both ports):
//  *
//  *              PORT 1  (spi21 / LSSPI)     PORT 2  (spi00 / HSSPI)
//  *   SCK        P1.07  →  Pico GPIO18       P2.06  →  Pico GPIO18
//  *   MOSI       P1.09  →  Pico GPIO19       P2.09  →  Pico GPIO19
//  *   MISO       P1.00  →  Pico GPIO20       P2.02  →  Pico GPIO20
//  *   CSN        P1.10  →  Pico GPIO22       P2.10  →  Pico GPIO22
//  *
//  * spi21 = LSSPI  — max ~8 MHz in practice, any P1.xx pin works.
//  * spi00 = HSSPI  — up to 32 MHz, pins are fixed to the P2 HSSPI block.
//  */


// /* ══════════════════  PORT 1 — spi21 / LSSPI  (ACTIVE)  ═══════════════════════ */

// / {
// 	aliases {
// 		led = &led0;
// 		spis = &spi21;
// 	};
// };

